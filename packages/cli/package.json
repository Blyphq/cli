{
  "name": "@blyp/cli",
  "version": "0.1.52",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/Blyphq/cli"
  },
  "homepage": "https://github.com/Blyphq/cli",
  "bugs": {
    "url": "https://github.com/Blyphq/cli/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "blyp": "./dist/index.js"
  },
  "files": [
    "dist",
    "studio"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "node ./scripts/build-studio.mjs && tsc -p tsconfig.build.json && chmod +x dist/index.js",
    "check-types": "tsc -p tsconfig.json --noEmit",
    "dev": "bun run ./src/index.ts",
    "test": "vitest run",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.107",
    "@base-ui/react": "^1.0.0",
    "@clack/prompts": "^0.11.0",
    "@openrouter/ai-sdk-provider": "^2.3.0",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@streamdown/cjk": "^1.0.2",
    "@streamdown/code": "^1.1.0",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@tanstack/react-query": "^5.80.6",
    "@tanstack/react-router": "^1.154.3",
    "@trpc/client": "^11.11.0",
    "@trpc/server": "^11.11.0",
    "@trpc/tanstack-react-query": "^11.11.0",
    "ai": "^6.0.116",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jiti": "^2.6.1",
    "lucide-react": "^0.577.0",
    "motion": "^12.36.0",
    "nanoid": "^5.1.6",
    "next-themes": "^0.4.6",
    "open": "^11.0.0",
    "react": "19.2.3",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.3",
    "sonner": "^2.0.3",
    "streamdown": "^2.4.0",
    "tailwind-merge": "^3.3.1",
    "use-stick-to-bottom": "^1.1.3",
    "zod": "^4.1.13",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@blyp-cli/config": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
