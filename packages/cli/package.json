{
  "name": "@blyp/cli",
  "version": "0.1.0",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "blyphq": "./dist/index.js"
  },
  "files": [
    "dist",
    "skills"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x dist/index.js",
    "check-types": "tsc -p tsconfig.json --noEmit",
    "dev": "bun run ./src/index.ts",
    "test": "vitest run",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "jiti": "^2.6.1",
    "open": "^11.0.0"
  },
  "devDependencies": {
    "@blyp-cli/config": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
