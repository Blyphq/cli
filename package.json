{
  "name": "blyp-cli",
  "version": "0.1.51",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "@types/node": "^22.13.14",
      "@trpc/server": "^11.11.0",
      "@trpc/client": "^11.11.0",
      "jsdom": "^26.0.0",
      "vitest": "^3.1.1",
      "@vitest/ui": "^3.1.1",
      "@vitest/coverage-v8": "^3.1.1"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev --filter=!@blyp/cli",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "cli": "bun run ./packages/cli/src/index.ts",
    "dev:cli": "bun run --watch ./packages/cli/src/index.ts",
    "build:cli": "turbo -F @blyp/cli build",
    "check-types:cli": "turbo -F @blyp/cli check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev"
  },
  "dependencies": {
    "@blyp-cli/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@blyp-cli/config": "workspace:*",
    "@types/node": "catalog:",
    "turbo": "^2.6.3",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.9"
}
